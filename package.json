{
  "name": "rdflib-cdt",
  "version": "0.1.0",
  "description": "Standalone extension for rdflib.js — Custom Datatypes (CDT) with UCUM unit-aware equality, comparison, conversion, and arithmetic.",
  "main": "lib/index.js",
  "module": "esm/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "src",
    "lib",
    "esm"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:all": "npm run build && npm run build:esm",
    "test": "mocha --require ./tests/register.js tests/**/*.ts",
    "test:verify": "node tests/verify.js",
    "test:test": "node tests/test.js",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "clean": "rimraf lib esm",
    "prepublishOnly": "npm run clean && npm run build:all && npm run test"
  },
  "peerDependencies": {
    "rdflib": ">=2.0.0"
  },
  "dependencies": {
    "@lhncbc/ucum-lhc": "^5.0.0",
    "decimal.js": "^10.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-typescript": "^7.28.0",
    "@babel/register": "^7.28.0",
    "@types/chai": "^5.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.5.0",
    "mocha": "^10.8.0",
    "rdflib": "^2.3.5",
    "rimraf": "^5.0.0",
    "source-map-support": "^0.5.21",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "rdf",
    "rdflib",
    "ucum",
    "units",
    "custom-datatypes",
    "linked-data",
    "quantity",
    "measurement",
    "semantic-web"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_USER/rdflib-cdt.git"
  }
}
